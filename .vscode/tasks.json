{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build (Release-MT|x64)",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\tools\\build.ps1",
                "-Configuration",
                "Release-MT",
                "-Platform",
                "x64"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile",
            "detail": "Builds NV3D-Glass. The vcxproj's PreBuildEvent first builds NV3DLib (lib only, samples skipped)."
        },
        {
            "label": "rebuild (Release-MT|x64)",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\tools\\build.ps1",
                "-Configuration",
                "Release-MT",
                "-Platform",
                "x64",
                "-Target",
                "Rebuild"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "clean (Release-MT|x64)",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\tools\\build.ps1",
                "-Configuration",
                "Release-MT",
                "-Platform",
                "x64",
                "-Target",
                "Clean"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build NV3DLib only (Release-MT|x64)",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\external\\NV3D-Lib\\tools\\build.ps1",
                "-Configuration",
                "Release-MT",
                "-Platform",
                "x64",
                "-Target",
                "NV3DLib"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile",
            "detail": "Builds only the NV3DLib submodule (skips samples). Use when iterating on submodule code without rebuilding the app."
        },
        {
            "label": "build NV3DLib + samples (Release-MT|x64)",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\external\\NV3D-Lib\\tools\\build.ps1",
                "-Configuration",
                "Release-MT",
                "-Platform",
                "x64"
            ],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$msCompile",
            "detail": "Builds NV3DLib AND the DX11/DX12/OGL/Vulkan sample apps. Use when working on or verifying the samples."
        }
    ]
}
